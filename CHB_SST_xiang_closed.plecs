                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "Ts"
                      Value         "[0, 0; 1/f_sw, 0]"
                      Show          off
                    }
                    Parameter {
                      Variable      "Parameters"
                      Value         "num_module"
                      Show          off
                    }
                    Parameter {
                      Variable      "LangStandard"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "GnuExtensions"
                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "RuntimeCheck"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "Declarations"
                      Value         "#include <stdlib.h>\n"
"#include <stdio.h>\n"
"#include <math.h>\n"
"\n"
"typedef struct\n"
"{\n"
"\tint index_cap;\n"
"   double v_cap;\n"
"} module;\n"
"\n"
"static int num_module;\n"
"static module *module_array = NULL;\n"
"static int *output_index_array;"
                      Show          off
                    }
                    Parameter {
                      Variable      "StartFcn"
                      Value         "num_module = ParamRealData(0,0);\n"
"\n"
"module_array = (module*) malloc(num_module*sizeof(module));\n"
"output_index_array = (int*) malloc(num_module*sizeof(int));\n"
"for(int index=0; index<num_module; index++)\n"
"{\n"
"\toutput_index_array[index] = index;\n"
"}"
                      Show          off
                    }
                    Parameter {
                      Variable      "OutputFcn"
                      Value         "if(IsMajorStep)\n"
"{\n"
"\tif(IsSampleHit(1))\n"
"\t{\n"
"\t\tfor(int index=0; index<num_module; index++)\n"
"\t\t{\n"
"\t\t\tmodule_array[index].index_cap = index;\n"
"\t\t\tmodule_array[index].v_cap = Input(num_module + index);\n"
"\t\t}\n"
"\t\n"
"\t\tif(Input(2*num_module)>=0)\n"
"\t\t{\n"
"\t\t\tfor(int index_a=0; index_a<num_module; index_a++)\n"
"\t\t\t{\n"
"\t\t\t\tfor(int index_b=index_a+1; index_b<num_module; index_b++)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tif(module_array[index_b].v_cap < module_array[index_a].v_cap)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tmodule module_temp;\n"
"\t\t\t\t\t\tmodule_temp.index_cap = module_array[index_b].index_cap;\n"
"\t\t\t\t\t\tmodule_temp.v_cap = module_array[index_b].v_cap;\n"
"\t\t\t\t\t\n"
"\t\t\t\t\t\tmodule_array[index_b].index_cap = module_array[index_a].index_cap"
";\n"
"\t\t\t\t\t\tmodule_array[index_b].v_cap = module_array[index_a].v_cap;\n"
"\t\t\t\t\t\n"
"\t\t\t\t\t\tmodule_array[index_a].index_cap = module_temp.index_cap;\n"
"\t\t\t\t\t\tmodule_array[index_a].v_cap = module_temp.v_cap;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t}\n"
"\t\t\t}\n"
"\t\t}\n"
"\t\telse\n"
"\t\t{\n"
"\t\t\tfor(int index_a=0; index_a<num_module; index_a++)\n"
"\t\t\t{\n"
"\t\t\t\tfor(int index_b=index_a+1; index_b<num_module; index_b++)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tif(module_array[index_b].v_cap > module_array[index_a].v_cap)\n"
"\t\t\t\t\t{\n"
"\t\t\t\t\t\tmodule module_temp;\n"
"\t\t\t\t\t\tmodule_temp.index_cap = module_array[index_b].index_cap;\n"
"\t\t\t\t\t\tmodule_temp.v_cap = module_array[index_b].v_cap;\n"
"\t\t\t\t\t\n"
"\t\t\t\t\t\tmodule_array[index_b].index_cap = module_array[index_a].index_cap"
";\n"
"\t\t\t\t\t\tmodule_array[index_b].v_cap = module_array[index_a].v_cap;\n"
"\t\t\t\t\t\n"
"\t\t\t\t\t\tmodule_array[index_a].index_cap = module_temp.index_cap;\n"
"\t\t\t\t\t\tmodule_array[index_a].v_cap = module_temp.v_cap;\n"
"\t\t\t\t\t}\n"
"\t\t\t\t}\n"
"\t\t\t}\n"
"\t\t}\n"
"\t\n"
"\t\tfor(int index = 0;index<num_module; index++)\n"
"\t\t{\n"
"\t\t\toutput_index_array[index] = module_array[index].index_cap; \n"
"\t\t}\n"
"\t}\n"
"}\n"
"\n"
"for(int index = 0; index<num_module; index++)\n"
"{\n"
"\tOutput(output_index_array[index]) = Input(index);\n"
"}"
                      Show          off
                    }
                    Parameter {
                      Variable      "UpdateFcn"
                      Value         ""
                      Show          off
                    }
                    Parameter {
                      Variable      "DerivativeFcn"
                      Value         ""
                      Show          off
                    }
                    Parameter {
                      Variable      "TerminateFcn"
                      Value         "free(module_array);\n"
"free(output_index_array);"
                      Show          off
                    }
                    Parameter {
                      Variable      "StoreCustomStateFcn"
                      Value         "for (int i = 0; i < num_module; ++i){\n"
"   WriteCustomStateInt(output_index_array[i]);\n"
"}\n"
                      Show          off
                    }
                    Parameter {
                      Variable      "RestoreCustomStateFcn"
                      Value         "for (int i = 0; i < num_module; ++i){\n"
"   output_index_array[i] = ReadCustomStateInt();\n"
"}"
                      Show          off
                    }
                  }
