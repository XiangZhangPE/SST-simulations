                      Show          off
                    }
                    Parameter {
                      Variable      "NumInputs"
                      Value         "[1 num_channel]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumOutputs"
                      Value         "[num_channel num_channel]"
                      Show          off
