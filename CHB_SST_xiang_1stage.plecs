                  Component {
                    Type          CScript
                    Name          "Carrier"
                    Show          on
                    Position      [210, 95]
                    Direction     up
                    Flipped       off
                    LabelPosition south
                    Parameter {
                      Variable      "DialogGeometry"
                      Value         "[578 68 994 1310]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumInputs"
                      Value         "[1 num_channel]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumOutputs"
                      Value         "[num_channel num_channel]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumContStates"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumDiscStates"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumZCSignals"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "DirectFeedthrough"
                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "Ts"
                      Value         "[0,0; -2,clk_cntr]"
                      Show          off
                    }
                    Parameter {
                      Variable      "Parameters"
                      Value         "clk_cntr, update,use_rel_phase"
                      Show          off
                    }
                    Parameter {
                      Variable      "LangStandard"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "GnuExtensions"
                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "RuntimeCheck"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "Declarations"
                      Value         "#include <float.h>\n"
"#include <stdlib.h>\n"
"#include <stdint.h>\n"
"\n"
"#define clk_cntr ParamRealData(0,0)\n"
"#define use_rel_phase ParamRealData(2,0)\n"
"\n"
"#define num_channel NumInputSignals(1)\n"
"\n"
"static double cntr_max_buf;\n"
"typedef struct\n"
"{\n"
"\tdouble cntr;\n"
"\tint64_t tick;\n"
"\tdouble dirc;\n"
"} samplehit;\n"
"static samplehit *samplehit_pre_buf = NULL;\n"
"static samplehit *samplehit_1st_buf = NULL;\n"
"static samplehit *samplehit_2nd_buf = NULL;\n"
"static samplehit *samplehit_3rd_buf = NULL;\n"
"static int update_option;\n"
"static int first_step = 0;\n"
"\n"
"void update_samplehit(int id_channel, double cntr_max, double ph, double clk,"
" int64_t currentTick, \n"
"\tsamplehit* buf_pre, samplehit* buf_1st, samplehit* buf_2nd, samplehit* buf_"
"3rd)\n"
"{\n"
"\tdouble phase_shift = ph*cntr_max;\n"
"\t// check if phase difference to carrier minimum is within one tick\n"
"\tif ((int)(phase_shift+0.5) == (int)(cntr_max+0.5) || (int)(phase_shift+0.5)"
" == 0) \n"
"\t   phase_shift = 0;\n"
"\t\n"
"\tif (phase_shift == 0)\n"
"\t{\n"
"\t\t(buf_pre+id_channel)->cntr = 0;\n"
"\t\t(buf_pre+id_channel)->tick = currentTick + 0.;\n"
"\t\t(buf_pre+id_channel)->dirc = 1.;\n"
"\t\t(buf_1st+id_channel)->cntr = 0.;\n"
"\t\t(buf_1st+id_channel)->tick = currentTick + cntr_max + phase_shift + 0.5;"
"\n"
"\t\t(buf_1st+id_channel)->dirc = 1.;\n"
"\t\t(buf_2nd+id_channel)->cntr = 0.;\n"
"\t\t(buf_2nd+id_channel)->tick = currentTick + 2*cntr_max + phase_shift + 0.5"
";\n"
"\t\t(buf_2nd+id_channel)->dirc = 1.;\n"
"\t\t(buf_3rd+id_channel)->cntr = 0.;\n"
"\t\t(buf_3rd+id_channel)->tick = currentTick + 3*cntr_max + phase_shift + 0.5"
";\n"
"\t\t(buf_3rd+id_channel)->dirc = 1.;\n"
"\t}\n"
"\telse\n"
"\t{\n"
"\t\t(buf_pre+id_channel)->cntr = cntr_max - phase_shift;\n"
"\t\t(buf_pre+id_channel)->tick = currentTick + 0.;\n"
"\t\t(buf_pre+id_channel)->dirc = 1.;\n"
"\t\t(buf_1st+id_channel)->cntr = 0.;\n"
"\t\t(buf_1st+id_channel)->tick = currentTick + phase_shift + 0.5;\n"
"\t\t(buf_1st+id_channel)->dirc = 1.;\n"
"\t\t(buf_2nd+id_channel)->cntr = 0.;\n"
"\t\t(buf_2nd+id_channel)->tick = currentTick + 1*cntr_max + phase_shift + 0.5"
";\n"
"\t\t(buf_2nd+id_channel)->dirc = 1.;\n"
"\t\t(buf_3rd+id_channel)->cntr = 0.;\n"
"\t\t(buf_3rd+id_channel)->tick = currentTick + 2*cntr_max + phase_shift + 0.5"
";\n"
"\t\t(buf_3rd+id_channel)->dirc = 1.;\n"
"\t}\n"
"}\n"
                      Show          off
                    }
                    Parameter {
                      Variable      "StartFcn"
                      Value         "NextSampleHit = DBL_MAX;\n"
"samplehit_pre_buf = (samplehit*) malloc(num_channel*sizeof(samplehit));\n"
"samplehit_1st_buf = (samplehit*) malloc(num_channel*sizeof(samplehit));\n"
"samplehit_2nd_buf = (samplehit*) malloc(num_channel*sizeof(samplehit));\n"
"samplehit_3rd_buf = (samplehit*) malloc(num_channel*sizeof(samplehit));\n"
"update_option = ParamRealData(1,0);\n"
"first_step = 1;"
                      Show          off
                    }
                    Parameter {
                      Variable      "OutputFcn"
                      Value         "if(IsMajorStep)\n"
"{\n"
"   static double last_phase0 = 0;\n"
"   int64_t tick = CurrentTime / clk_cntr + 0.5;\n"
"\tif (first_step)\n"
"\t{\n"
"\t\tcntr_max_buf = InputSignal(0,0);\n"
"\t   double phase0 = InputSignal(1, 0);\n"
"\t\tfor (int channel = 0; channel < num_channel; channel++)\n"
"\t\t{\n"
"\t\t   double phase;\n"
"\t\t   if (channel == 0)\n"
"\t\t      phase = phase0;\n"
"\t\t   else if (use_rel_phase)\n"
"\t\t      phase = InputSignal(1, channel) + phase0;\n"
"\t\t   else\n"
"\t\t   \tphase = InputSignal(1, channel);\n"
"\t      if (phase < 0) phase += 1.0;\n"
"\t      if (phase > 1.0) phase -= 1.0;\n"
"\t\t\tupdate_samplehit(channel, cntr_max_buf, phase, clk_cntr, tick, \n"
"\t\t\t\tsamplehit_pre_buf, samplehit_1st_buf, samplehit_2nd_buf, samplehit_3r"
"d_buf);\n"
"   \t}\n"
"      last_phase0 = phase0;\n"
"\t}\n"
"\telse if(IsSampleHit(1))\n"
"\t{\t\t\t \t\t\n"
"\t\tcntr_max_buf = InputSignal(0,0);\n"
"\t   int64_t tick = CurrentTime / clk_cntr + 0.5;\n"
"\t   // printf(\"Time %e, tick %lld\\n\", CurrentTime, tick);\n"
"\t\tif(samplehit_1st_buf[0].tick <= tick && samplehit_1st_buf[0].dirc == 1.)"
"\n"
"\t\t{\n"
"\t\t   double phase0 = InputSignal(1, 0);\n"
"\t\t\tfor (int channel = 0; channel < num_channel; channel++)\n"
"\t\t\t{\n"
"\t\t\t   double phase;\n"
"\t\t\t   if (channel == 0)\n"
"\t\t\t   \tphase = phase0 - last_phase0;\n"
"\t\t\t   else if (use_rel_phase)\n"
"\t\t\t      phase = InputSignal(1, channel) + phase0 - last_phase0;\n"
" \t\t\t\telse\n"
"\t\t   \t\tphase = InputSignal(1, channel) - last_phase0;\n"
"\t\t      if (phase < 0) phase += 1.0;\n"
"\t\t      if (phase > 1.0) phase -= 1.0;\n"
"\t\t\t\tupdate_samplehit(channel, cntr_max_buf, phase, clk_cntr, tick, \n"
"\t\t\t\t\tsamplehit_pre_buf, samplehit_1st_buf, samplehit_2nd_buf, samplehit_"
"3rd_buf);\n"
"\t   \t}\n"
"\t      last_phase0 = phase0;\t   \t\n"
"\t   }\n"
"\t   else\n"
"\t   {\n"
"\t\t\tfor (int id_channel = 0; id_channel < num_channel; id_channel++)\n"
"\t\t\t{\t\t\t\n"
"\t\t   \t// printf(\"  1st: %lld\\n\", samplehit_1st_buf[id_channel].time);\n"
"\t\t\t\tif(samplehit_1st_buf[id_channel].tick <= tick)\n"
"\t\t\t\t{\n"
"\t\t\t\t\tsamplehit_pre_buf[id_channel].cntr = samplehit_1st_buf[id_channel]."
"cntr;\n"
"\t\t\t\t\tsamplehit_pre_buf[id_channel].tick = samplehit_1st_buf[id_channel]."
"tick;\n"
"\t\t\t\t\tsamplehit_pre_buf[id_channel].dirc = samplehit_1st_buf[id_channel]."
"dirc;\n"
"\t\t\t\t\tsamplehit_1st_buf[id_channel].cntr = samplehit_2nd_buf[id_channel]."
"cntr;\n"
"\t\t\t\t\tsamplehit_1st_buf[id_channel].tick = samplehit_2nd_buf[id_channel]."
"tick;\n"
"\t\t\t\t\tsamplehit_1st_buf[id_channel].dirc = samplehit_2nd_buf[id_channel]."
"dirc;\t\n"
"\t\t\t\t\tsamplehit_2nd_buf[id_channel].cntr = samplehit_3rd_buf[id_channel]."
"cntr;\n"
"\t\t\t\t\tsamplehit_2nd_buf[id_channel].tick = samplehit_3rd_buf[id_channel]."
"tick;\n"
"\t\t\t\t\tsamplehit_2nd_buf[id_channel].dirc = samplehit_3rd_buf[id_channel]."
"dirc;\t\n"
"\t\t\t\t}\t\t\t\t\n"
"\t\t\t}\t\t\t\n"
"  \t\t}\n"
"  \t}\n"
"  \tif (IsSampleHit(1) || first_step)\n"
"  \t{\n"
"  \t\t// Configure the closest sample hit in the future\n"
"   \tint64_t next_event = tick + 2*cntr_max_buf+0.5;\n"
"   \tfor (int id_channel = 0; id_channel < num_channel; id_channel++)\n"
"\t\t{\t\t\n"
"  \t\t\tif(samplehit_1st_buf[id_channel].tick < next_event && samplehit_1st_b"
"uf[id_channel].tick > tick)\n"
"  \t\t\t{\n"
"  \t\t\t\tnext_event = samplehit_1st_buf[id_channel].tick;\n"
"  \t\t\t}\n"
"  \t\t}\n"
"  \t\tNextSampleHit = next_event*clk_cntr;\n"
"  \t\t// printf(\"  Next: %e\\n\", NextSampleHit);\n"
"  \t}\n"
"}\n"
"\n"
"// Interpolate the carrier output at minor steps and output the synchrnoisati"
"on impulse\n"
"for (int id_channel = 0; id_channel < num_channel; id_channel++)\n"
"{\t\n"
"   double output;\n"
"\toutput = samplehit_pre_buf[id_channel].cntr +  \n"
"\t\t\t\t(CurrentTime/clk_cntr - samplehit_pre_buf[id_channel].tick);\n"
"\tif (output > cntr_max_buf)\n"
"\t   output = cntr_max_buf;\n"
"\tif (output < 0.0)\n"
"\t   output = 0.0;\n"
"\tOutputSignal(0,id_channel) = output;\n"
"\tint int_output = output+0.5;\n"
"\tif(update_option!=2)\n"
"\t{\n"
"\t\tif(int_output == 0. || int_output == (int)(cntr_max_buf+0.5))\n"
"\t\t{\n"
"\t\t\tOutputSignal(1,id_channel) = 1.;\t\t\t\t\t\t\t\n"
"\t\t}\n"
"\t\telse\n"
"\t\t{\n"
"\t\t\tOutputSignal(1,id_channel) = 0.;\n"
"\t\t}\n"
"\t}\n"
"}\n"
"\n"
"\n"
                      Show          off
                    }
                    Parameter {
                      Variable      "UpdateFcn"
                      Value         "first_step = 0;\n"
                      Show          off
                    }
                    Parameter {
                      Variable      "DerivativeFcn"
                      Value         ""
                      Show          off
                    }
                    Parameter {
                      Variable      "TerminateFcn"
                      Value         "free(samplehit_pre_buf);\n"
"free(samplehit_1st_buf);\n"
"free(samplehit_2nd_buf);\n"
"free(samplehit_3rd_buf);\n"
                      Show          off
                    }
                    Parameter {
                      Variable      "StoreCustomStateFcn"
                      Value         ""
                      Show          off
                    }
                    Parameter {
                      Variable      "RestoreCustomStateFcn"
                      Value         ""
                      Show          off
                    }
