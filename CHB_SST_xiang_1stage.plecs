                    Points        [260, 90; 260, 65]
                    DstComponent  "cntr"
                    DstTerminal   1
                  }
                }
                Name          "Symmetrical"
                Schematic {
                  Component {
                    Type          Input
                    Name          "prd"
                    Show          on
                    Position      [60, 60]
                    Direction     right
                    Flipped       off
                    LabelPosition south
                    Parameter {
                      Variable      "Index"
                      Value         "1"
                      Show          on
                    }
                    Parameter {
