"\t}\n"
"\tif(Input(0)==0. && nonzero_received==1)\n"
"\t{\n"
"\t\tOutput(1) = 1; //Error \n"
"\t}\n"
"}\n"
"if(nonzero_received)\n"
"{\n"
"\tOutput(0) = Input(0);\n"
"}\n"
"else\n"
"{\n"
"\tOutput(0) = 1.;\n"
"}"
