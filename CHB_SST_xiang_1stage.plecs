Plecs {
  Name          "CHB_SST_xiang_1stage"
  Version       "4.7"
  CircuitModel  "ContStateSpace"
  StartTime     "0"
  TimeSpan      "0.2"
  Timeout       ""
  Solver        "auto"
  MaxStep       "1e-6"
  InitStep      "-1"
  FixedStep     "1e-6"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-6"
  AbsTol        "-1"
  TurnOnThreshold "0"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "1"
  DivisionByZeroMsg "1"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "1"
  InitializationCommands "V_gpeak = 1280; % peak grid phase voltage (V)\nf_g ="
" 50; % grid frequency (Hz)\n\nV_dc = V_gpeak; % DC bus reference voltage sum "
"(V)\nnum_sm = 4; % number of series cells\nV_sm = V_dc/num_sm; % DC capacitor"
" initial voltage (V)\nC_sm = 0.8e-3; % DC bus capacitance (F)\n\nP_ref = 3.1e"
"6; % MMC injected Real Power reference (Watt)\nQ_ref = 0; % MMC injected Reac"
"tive Power reference (Watt)\n\nC_sm_vector = C_sm * ones(1, num_sm); % DC bus"
" capacitance vector (F)\nV_sm_vector = V_sm * ones(1, num_sm); % DC capacitor"
" initial voltage vector (V)\ncarrier_min = [0:1/num_sm:(1 - 1/num_sm)]; % Min"
"imum carrier signal values\ncarrier_max = [1/num_sm:1/num_sm:1]; % Maximum ca"
"rrier signal values\n\nL_g = 100e-6; % Grid equivalent inductance (Henries)\n"
"C_g = 46e-9;\nR_g = 0.6; % Grid equivalent resitance (ohms)\n\nf_sw = 2000; %"
" Triangle carrier wave frequency (Hz)\nT_HIL = 1/f_sw/100; % discretization s"
"tep-size\n\n% AC-DC DAB setup\nVg = V_gpeak/num_sm;\nVh = 300;\n\n%Lr1 = 3.1e"
"-6; Lr2 = 3.1e-6;\nLr1 = 6e-6; Lr2 = 0.2e-6;\nCr1 = 30e-6; Cr2 = 30e-6;\nLm ="
" 40e-6;\n\nfs = 100e3;\nTs = 1/fs;\nIzvs_th = 0.2;\n\nCoss1 = 132e-12; Coss2 "
"= 132e-12;\ntd1 = 50e-9; td2 = 50e-9;\n\nRds1 = 36e-3;\nRds2 = 50e-3;\n"
  InitialState  "1"
