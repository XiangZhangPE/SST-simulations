                  Component {
                    Type          CScript
                    Name          "Carrier"
                    Show          on
                    Position      [210, 95]
                    Direction     up
                    Flipped       off
                    LabelPosition south
                    Parameter {
                      Variable      "DialogGeometry"
                      Value         "[1553 547 1287 1304]"
