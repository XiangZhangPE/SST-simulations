                    }
                    Parameter {
                      Variable      "NumInputs"
                      Value         "[1 num_channel]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumOutputs"
                      Value         "[num_channel num_channel]"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumContStates"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumDiscStates"
                      Value         "0"
