                  Component {
                    Type          CScript
                    Name          "Carrier"
                    Show          on
                    Position      [210, 95]
                    Direction     up
                    Flipped       off
                    LabelPosition south
                    Parameter {
                      Variable      "DialogGeometry"
                      Value         "[578 68 994 1310]"
