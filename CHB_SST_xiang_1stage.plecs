                    SrcComponent  "Carrier"
                    SrcTerminal   4
                    DstComponent  "sync"
                    DstTerminal   1
                  }
                  Connection {
                    Type          Signal
                    SrcComponent  "Carrier"
                    SrcTerminal   3
                    Points        [260, 90; 260, 65]
                    DstComponent  "cntr"
                    DstTerminal   1
                  }
