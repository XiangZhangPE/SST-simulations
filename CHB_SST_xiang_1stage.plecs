            Value         "2"
            Show          off
            Tunable       off
            TabName       ""
          }
          Parameter {
            Variable      "sys_clk"
            Prompt        "sys_clk"
            Type          FreeText
            Value         "1e-9"
            Show          off
            Tunable       off
            TabName       ""
          }
