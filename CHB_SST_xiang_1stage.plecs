                      Value         "width*2"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumOutputs"
                      Value         "width"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumContStates"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumDiscStates"
                      Value         "width"
                      Show          off
                    }
                    Parameter {
                      Variable      "NumZCSignals"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "DirectFeedthrough"
                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "Ts"
                      Value         "0"
                      Show          off
                    }
                    Parameter {
                      Variable      "Parameters"
                      Value         "width"
                      Show          off
                    }
                    Parameter {
                      Variable      "LangStandard"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "GnuExtensions"
                      Value         "1"
                      Show          off
                    }
                    Parameter {
                      Variable      "RuntimeCheck"
                      Value         "2"
                      Show          off
                    }
                    Parameter {
                      Variable      "Declarations"
                      Value         "#include <stdlib.h>\n"
"#include <math.h>\n"
"#include <string.h>\n"
"#include <limits.h>\n"
"#include <float.h>\n"
"\n"
"static int num_channel;\n"
"static int first_step;"
                      Show          off
                    }
                    Parameter {
                      Variable      "StartFcn"
                      Value         "num_channel = ParamRealData(0,0);\n"
"first_step = 0;"
                      Show          off
                    }
                    Parameter {
                      Variable      "OutputFcn"
                      Value         "if(IsMajorStep)\n"
"{\n"
"\tfor(int id = 0; id < num_channel; id++)\n"
"\t{\n"
"\t\tif((Input(id) == 1 && DiscState(id) == 0) || first_step)\n"
"\t\t{\n"
"\t\t\tOutput(id) = Input(num_channel+id);\n"
"\t\t}\n"
"\t}\n"
"}"
                      Show          off
                    }
                    Parameter {
                      Variable      "UpdateFcn"
                      Value         "for(int id = 0; id < num_channel; id++)\n"
"{\n"
"\tDiscState(id) = Input(id);\n"
"}\n"
"first_step = 1;"
                      Show          off
