                    SrcComponent  "ph"
                    SrcTerminal   1
                    DstComponent  "Carrier"
                    DstTerminal   2
                  }
                  Connection {
                    Type          Signal
                    SrcComponent  "Gain"
                    SrcTerminal   2
                    Points        [140, 60; 140, 90]
                    DstComponent  "Carrier"
                    DstTerminal   1
                  }
                }
