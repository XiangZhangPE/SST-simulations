                    Name          "Sorting"
                    Show          on
                    Position      [175, 80]
                    Direction     up
                    Flipped       off
                    LabelPosition south
                    Parameter {
                      Variable      "DialogGeometry"
                      Value         "[1009 45 698 843]"
                      Show          off
